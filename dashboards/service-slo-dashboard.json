{
  "title": "Service SLO Overview",
  "uid": "service-slo-overview",
  "schemaVersion": 39,
  "editable": true,
  "tags": ["slo", "availability"],
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(http_requests_total, job)",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability (last 1h)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - job:slo_errors_per_request:ratio_rate1h{job=\"$job\"}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error ratio (5m vs 1h)",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "refId": "A",
          "expr": "job:slo_errors_per_request:ratio_rate5m{job=\"$job\"}",
          "legendFormat": "5m"
        },
        {
          "refId": "B",
          "expr": "job:slo_errors_per_request:ratio_rate1h{job=\"$job\"}",
          "legendFormat": "1h"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request rate by status class",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (code) (rate(http_requests_total{job=\"$job\"}[5m]))",
          "legendFormat": "{{ code }}"
        }
      ]
    }
  ]
}
